# ==============================================================
# NeuroPlan AI — Environment Variables Template
# ==============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ==============================================================


# --------------------------------------------------------------
# SUPABASE
# Found at: https://supabase.com/dashboard/project/<your-ref>/settings/api
# --------------------------------------------------------------

# Your project's public URL
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Your project's anon (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>


# --------------------------------------------------------------
# GROQ AI
# Found at: https://console.groq.com/keys
# Used for AI-powered study schedule generation (free tier).
# Recommended model: llama-3.3-70b-versatile
# --------------------------------------------------------------

GROQ_API_KEY=<your-groq-api-key>


# --------------------------------------------------------------
# CRON SECRET
# A random, hard-to-guess string you generate yourself.
# Used to authenticate Vercel Cron Job requests so only Vercel
# (not the public) can trigger /api/cron/* routes.
#
# Generate one with: openssl rand -base64 32
# Also add this to your Vercel project environment variables.
# --------------------------------------------------------------

CRON_SECRET=<your-random-secret-string>
